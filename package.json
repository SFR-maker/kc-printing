{
  "name": "kc-printing",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:all": "npm run typecheck && npm run lint && npm run test && npm run test:e2e",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts",
    "seed:card-templates": "tsx scripts/seed-card-templates.ts",
    "audit": "npm run typecheck && npm run lint && npm run build",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@clerk/nextjs": "^7.5.9",
    "@hookform/resolvers": "^5.4.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@stripe/stripe-js": "^9.8.0",
    "@types/pg": "^8.20.0",
    "@uploadthing/react": "^7.3.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.4.0",
    "dotenv": "^17.4.2",
    "file-type": "^22.0.1",
    "framer-motion": "^12.42.0",
    "isomorphic-dompurify": "^3.19.0",
    "konva": "^10.3.0",
    "lucide-react": "^1.21.0",
    "next": "16.2.9",
    "next-sitemap": "^4.2.3",
    "pdfkit": "^0.19.1",
    "pg": "^8.22.0",
    "prisma": "^7.8.0",
    "qrcode": "^1.5.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.80.0",
    "react-konva": "^19.2.5",
    "resend": "^6.16.0",
    "shadcn": "^4.12.0",
    "sharp": "^0.35.2",
    "stripe": "^22.3.0",
    "svg-to-pdfkit": "^0.1.8",
    "svix": "^1.96.1",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "uploadthing": "^7.7.4",
    "uuid": "^14.0.1",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
